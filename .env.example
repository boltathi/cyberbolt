# ─── CyberBolt Environment Configuration ─────
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# ⚠️  CHANGE: SECRET_KEY, JWT_SECRET_KEY, ADMIN_PASSWORD, Redis password
# Generate secrets: openssl rand -hex 32

# Flask
FLASK_ENV=production
SECRET_KEY=CHANGE-ME-openssl-rand-hex-32
DEBUG=false

# JWT
JWT_SECRET_KEY=CHANGE-ME-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Redis — add your password after the colon   redis://:YOUR_PASSWORD@host:port/db
# If Redis has no password, use:               redis://localhost:6379/0
# ⚠️  URL-encode special chars in password:  @ → %40   # → %23   : → %3A

REDIS_URL=redis://:pwd%4024@localhost:6379/0
REDIS_SESSION_URL=redis://:pwd%4024@localhost:6379/1
REDIS_RATE_LIMIT_URL=redis://:pwd%4024@localhost:6379/2
REDIS_JWT_BLOCKLIST_URL=redis://:pwd%4024@localhost:6379/3
REDIS_DATA_URL=redis://:pwd%4024@localhost:6379/4

# CORS — your domain(s), comma separated
CORS_ORIGINS=https://cyberbolt.in,https://www.cyberbolt.in

# Rate Limiting
RATE_LIMIT_DEFAULT=200/hour
RATE_LIMIT_LOGIN=10/minute

# Admin (auto-created on first start — CHANGE THE PASSWORD!)
ADMIN_USERNAME=test
ADMIN_PASSWORD=CHANGE-ME-strong-password
ADMIN_EMAIL=bolt@cyberbolt.in

# Domain & URLs
DOMAIN=cyberbolt.in
NEXT_PUBLIC_API_URL=https://cyberbolt.in
INTERNAL_API_URL=http://127.0.0.1:5000
NEXT_PUBLIC_SITE_URL=https://cyberbolt.in

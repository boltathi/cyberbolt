# ─── CyberBolt Environment Configuration ─────
# Copy to .env and fill in your values

# Flask
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DEBUG=false

# JWT
JWT_SECRET_KEY=change-me-to-another-random-64-char-hex-string
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_URL=redis://redis:6379/1
REDIS_RATE_LIMIT_URL=redis://redis:6379/2
REDIS_JWT_BLOCKLIST_URL=redis://redis:6379/3

# CORS
CORS_ORIGINS=http://localhost:3000,https://cyberbolt.in,https://www.cyberbolt.in

# Rate Limiting
RATE_LIMIT_DEFAULT=200/hour
RATE_LIMIT_LOGIN=10/minute

# Admin (auto-created on first start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_EMAIL=admin@cyberbolt.in

# Domain
DOMAIN=cyberbolt.in
NEXT_PUBLIC_API_URL=http://backend:5000
NEXT_PUBLIC_SITE_URL=https://cyberbolt.in

# Data
DATA_DIR=/app/data

# ─── CyberBolt Environment Configuration ─────
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# ⚠️  CHANGE: SECRET_KEY, JWT_SECRET_KEY, ADMIN_PASSWORD, Redis password
# Generate secrets: openssl rand -hex 32

# Flask
FLASK_ENV=production
SECRET_KEY=B5C4A380FA687D861102DD4B3EC39679DF37E45A7FAF4DE0EECA08CCA9F9FCBF
DEBUG=false

# JWT
JWT_SECRET_KEY=DE9B18221D98DFB7590B2CDF6B7E7FB526994137428CBD701F45D39E727B1E3C
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Redis — add your password after the colon   redis://:YOUR_PASSWORD@host:port/db
# If Redis has no password, use:               redis://localhost:6379/0
# ⚠️  URL-encode special chars in password:  @ → %40   # → %23   : → %3A

REDIS_URL=redis://:ZohoTest%4024@localhost:6379/0
REDIS_SESSION_URL=redis://:ZohoTest%4024@localhost:6379/1
REDIS_RATE_LIMIT_URL=redis://:ZohoTest%4024@localhost:6379/2
REDIS_JWT_BLOCKLIST_URL=redis://:ZohoTest%4024@localhost:6379/3
REDIS_DATA_URL=redis://:ZohoTest%4024@localhost:6379/4

# CORS — your domain(s), comma separated
CORS_ORIGINS=https://cyberbolt.in,https://www.cyberbolt.in

# Rate Limiting
RATE_LIMIT_DEFAULT=200/hour
RATE_LIMIT_LOGIN=10/minute

# Admin (auto-created on first start — CHANGE THE PASSWORD!)
ADMIN_USERNAME=bolt
ADMIN_PASSWORD=Boltworld@24
ADMIN_EMAIL=bolt@cyberbolt.in

# Domain & URLs
DOMAIN=cyberbolt.in
NEXT_PUBLIC_API_URL=https://cyberbolt.in
INTERNAL_API_URL=http://127.0.0.1:5000
NEXT_PUBLIC_SITE_URL=https://cyberbolt.in

# Contact Form — Gmail SMTP
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an "App Password" (requires 2FA enabled)
# 3. Paste the 16-character password below (no spaces)
SMTP_USER=helloboltworld24@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
CONTACT_EMAIL=helloboltworld24@gmail.com
